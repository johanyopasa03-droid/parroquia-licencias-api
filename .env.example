# Copia este archivo como .env (no lo subas a git)
# En Vercel, configura estas mismas variables en: Settings → Environment Variables

# Supabase → Settings → API → Project URL
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Supabase → Settings → API → service_role key (NO la anon key)
SUPABASE_SERVICE_KEY=eyJhbGci...

# Clave secreta para el panel admin (tú la defines, guárdala bien)
# Úsala en el header: x-api-key: <este valor>
ADMIN_API_KEY=pon-aqui-una-clave-larga-y-segura-2025
